FLASK_SECRET_KEY=change-this-to-a-random-string-in-production
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: http://localhost:5000/auth/github/callback
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# GitLab OAuth — https://gitlab.com/-/user_settings/applications
# Callback URL: http://localhost:5000/auth/gitlab/callback
# Scopes: read_api, read_repository
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Bitbucket OAuth — workspace settings → OAuth consumers
# Callback URL: http://localhost:5000/auth/bitbucket/callback
# Permissions: Account: Read, Repositories: Read
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
